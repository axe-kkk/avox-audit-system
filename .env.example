# Скопируйте в .env и заполните. Не коммитьте .env с секретами.
#
# Docker Compose на сервере сам подставляет DATABASE_URL в api/worker/migrate
# из POSTGRES_* ниже. Строка DATABASE_URL здесь нужна для локального запуска
# (uvicorn на машине без Docker-стека).

# --- PostgreSQL (образ db в compose; пароль без символов @ : / ? # & для URL) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_LONG_RANDOM
POSTGRES_DB=avox_revenue_gaps

# --- Локально без Docker API (uvicorn): укажите свой пароль и хост ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/avox_revenue_gaps

DEBUG=false
API_PREFIX=/api/v1

# CORS: локально — localhost; на сервере — ваш HTTPS-домен
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:8000,http://localhost:8000

OPENAI_API_KEY=
LLM_MODEL=gpt-4o
LLM_MODEL_MINI=gpt-4o-mini

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

PDF_OUTPUT_DIR=storage/pdfs

# В compose на сервере используйте redis://redis:6379/... (см. комментарий внизу)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Google Sheets: в Docker положите JSON в ./secrets/ и укажите путь в контейнере
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_SERVICE_ACCOUNT_FILE=
GOOGLE_SHEETS_WORKSHEET_TITLE=AVOX Submissions

# --- На сервере в .env замените Redis и CORS, например: ---
# ALLOWED_ORIGINS=https://audit.avox-development.pp.ua,https://avox-development.pp.ua
# REDIS_URL=redis://redis:6379/0
# CELERY_BROKER_URL=redis://redis:6379/0
# CELERY_RESULT_BACKEND=redis://redis:6379/1
# GOOGLE_SHEETS_SERVICE_ACCOUNT_FILE=/app/secrets/google-sa.json
